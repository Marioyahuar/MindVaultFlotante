{
  "productName": "MindVault Flotante",
  "version": "0.1.0",
  "identifier": "com.mindvault.flotante",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MindVault",
        "width": 420,
        "height": 260,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": true,
        "skipTaskbar": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
